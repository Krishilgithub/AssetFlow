  other_users_users_created_byTousers                        users[]                @relation("users_created_byTousers")
  users_users_deleted_byTousers                              users?                 @relation("users_deleted_byTousers", fields: [deleted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_users_users_deleted_byTousers                        users[]                @relation("users_deleted_byTousers")
  users_users_updated_byTousers                              users?                 @relation("users_updated_byTousers", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_users_users_updated_byTousers                        users[]                @relation("users_updated_byTousers")
  sessions                                                   sessions[]
  refreshTokens                                              refresh_tokens[]
  emailVerifications                                         email_verifications?
  passwordResetTokens                                        password_reset_tokens?
  loginHistories                                             login_history[]
  oauthAccounts                                              oauth_accounts[]
}

model sessions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  expires    DateTime  @db.Timestamptz(6)
  ip_address String?   @db.VarChar(45)
  user_agent String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model refresh_tokens {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token       String    @unique @db.VarChar(255)
  expires     DateTime  @db.Timestamptz(6)
  revoked     Boolean   @default(false)
  replaced_by String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model email_verifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @unique @db.Uuid
  email      String    @db.VarChar(255)
  otp_hash   String    @db.VarChar(255)
  expires    DateTime  @db.Timestamptz(6)
  attempts   Int       @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model password_reset_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @unique @db.Uuid
  token_hash String    @db.VarChar(255)
  expires    DateTime  @db.Timestamptz(6)
  used       Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model login_history {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  ip_address String?   @db.VarChar(45)
  user_agent String?
  os         String?   @db.VarChar(100)
  browser    String?   @db.VarChar(100)
  country    String?   @db.VarChar(100)
  status     String    @db.VarChar(50) // "SUCCESS", "FAILED", "LOCKED"
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model failed_logins {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  ip_address   String?   @db.VarChar(45)
  count        Int       @default(1)
  locked_until DateTime? @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model oauth_accounts {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  provider         String    @db.VarChar(50) // "google"
  provider_user_id String    @db.VarChar(255)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
}

model organization_settings {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_name String @default("AssetFlow Inc.") @db.VarChar(255)
  tax_id   String @default("TX-9428-11A") @db.VarChar(50)
  email    String @default("admin@company.com") @db.VarChar(255)
  address  String @default("Market St, San Francisco, CA") @db.VarChar(500)

  enable_email_alerts    Boolean @default(true)
  enable_audit_reminders Boolean @default(true)
  enable_warranty_alerts Boolean @default(true)

  min_password_length Int    @default(12)
  session_timeout     Int    @default(30)
  backup_schedule     String @default("Every 24 Hours") @db.VarChar(50)

  updated_at DateTime @default(now()) @db.Timestamptz(6)
}
