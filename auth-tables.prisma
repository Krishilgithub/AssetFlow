
model sessions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  expires      DateTime  @db.Timestamptz(6)
  ip_address   String?   @db.VarChar(45)
  user_agent   String?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model refresh_tokens {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  token        String    @unique @db.VarChar(255)
  expires      DateTime  @db.Timestamptz(6)
  revoked      Boolean   @default(false)
  replaced_by  String?   @db.VarChar(255)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model email_verifications {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @unique @db.Uuid
  email        String    @db.VarChar(255)
  otp_hash     String    @db.VarChar(255)
  expires      DateTime  @db.Timestamptz(6)
  attempts     Int       @default(0)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model password_reset_tokens {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @unique @db.Uuid
  token_hash   String    @db.VarChar(255)
  expires      DateTime  @db.Timestamptz(6)
  used         Boolean   @default(false)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model login_history {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  ip_address   String?   @db.VarChar(45)
  user_agent   String?
  os           String?   @db.VarChar(100)
  browser      String?   @db.VarChar(100)
  country      String?   @db.VarChar(100)
  status       String    @db.VarChar(50) // "SUCCESS", "FAILED", "LOCKED"
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model failed_logins {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  ip_address   String?   @db.VarChar(45)
  count        Int       @default(1)
  locked_until DateTime? @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model oauth_accounts {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  provider         String    @db.VarChar(50) // "google"
  provider_user_id String    @db.VarChar(255)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
}
